{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "background": true,
			"custom": true,
			"customDuotone": true,
			"customGradient": true,
			"defaultDuotone": true,
			"defaultGradients": true,
			"defaultPalette": false,
			"gradients": [],
      "palette": [
        { "slug": "primary",  "color": "light-dark(#1b2632, #FFB162)",  "name": "Primary" },
				{ "slug": "secondary","color": "light-dark(#A35139, #D48B71)",  "name": "Secondary" },
				{ "slug": "base",     "color": "light-dark(#EEE9DF, #1B2632)",  "name": "Base" },
				{ "slug": "contrast", "color": "light-dark(#C9C1B1, #5E758C)",  "name": "Contrast" },
				{ "slug": "neutral",  "color": "light-dark(#2C3B4D, #8899AA)",  "name": "Neutral" },
				{ "slug": "accent",   "color": "light-dark(#1B2632, #8AB4F8)",  "name": "Accent" }
      ],
      "text": true
    },
    "custom": {
			"animations": {
				"length": "350ms"
			},
			"line-height": {
				"large": 2.4,
				"medium": 1.7,
				"small": 1.2
			}
		},
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1680px"
    },
		"spacing": {
			"spacingScale": {
				"increment": 2,
				"mediumStep": 1,
				"operator": "*",
				"steps": 7,
				"unit": "rem"
			},
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
    "typography": {
      "customFontSize": true,
			"dropCap": true,
      "fluid": true,
      "fontFamilies": [
        {
          "name": "Fraunces",
          "slug": "fraunces",
          "fontFamily": "'Fraunces', serif",
          "fontFace": [
            {
              "fontFamily": "Fraunces",
              "fontWeight": "300 700",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/Fraunces.woff2" ]
            }
          ]
        },
        {
          "name": "Public Sans",
          "slug": "body",
          "fontFamily": "'Public Sans', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Public Sans",
              "fontWeight": "400 700",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/PublicSans.woff2" ]
            },
            {
              "fontFamily": "Public Sans",
              "fontWeight": "400 700",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/PublicSans-Italic.woff2" ]
            }
          ]
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "'JetBrains Mono', monospace",
          "fontFace": [
            {
              "fontFamily": "JetBrains Mono",
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/jetbrains-mono.woff2" ]
            }
          ]
        },
        {
          "name": "Atkinson Hyperlegible Next",
          "slug": "atkinson",
          "fontFamily": "'Atkinson Hyperlegible Next', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Atkinson Hyperlegible Next",
              "fontWeight": "200 800",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/AtkinsonHyperlegibleNext.woff2" ]
            },
            {
              "fontFamily": "Atkinson Hyperlegible Next",
              "fontWeight": "200 800",
              "fontStyle": "italic",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/AtkinsonHyperlegibleNextItalic.woff2" ]
            }
          ]
        }
      ],
			"fontSizes": [
				{
					"name": "Small",
					"size": "100%",
					"slug": "sm",
					"fluid": false
				},
				{
					"name": "Medium",
					"size": "133%",
					"slug": "md",
					"fluid": {
						"min": "133%",
						"max": "177%"
					}
				},
				{
					"name": "Large",
					"size": "177%",
					"slug": "lg",
					"fluid": {
						"min": "177%",
						"max": "237%"
					}
				},
        {
          "name": "Extra Large",
          "size": "237%",
          "slug": "xl",
          "fluid": {
            "min": "237%",
            "max": "315%"
          }
        },
        {
          "name": "Huge",
          "size": "315%",
          "slug": "huge",
          "fluid": {
            "min": "315%",
            "max": "420%"
          }
        }
      ],
      "fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true
    }
  },
  "styles": {
    "blocks": {
      "core/cover": {
        "dimensions": {
					"minHeight": "50%"
				},
        "color": {
          "background": "light-dark(#ddd6c6, #2a3648)",
          "text":       "light-dark(#2f251c, #c9c1b1)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)"
        },
        "variations": {
          "inline-dark": {
            "color": {
              "background": "#1e293b",
              "text":       "#94a3b8"
            }
          }
        }
      }
    },
    "css": ":root { color-scheme: light dark; }",
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--primary)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--secondary)"
        }
      }
    }
  },
  "templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "uncategorized",
			"name": "comments",
			"title": "Comments"
		}
	]
}